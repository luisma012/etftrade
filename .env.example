# Copy this file to .env and fill in your credentials
# Never commit real keys to git

# ── Alpaca (primary broker) ──────────────────────────────────
# Get keys at: https://alpaca.markets → paper trading is free
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Paper trading (default, safe for testing):
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Live trading (real money — change only when ready):
# ALPACA_BASE_URL=https://api.alpaca.markets

# ── Robinhood (optional, view-only) ──────────────────────────
RH_USERNAME=your_email@example.com
RH_PASSWORD=your_robinhood_password
