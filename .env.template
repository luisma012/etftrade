# .env.template — ETF Trader (no LLM / no Anthropic API key)
# Copy to .env and fill in your values.

# ── Broker selection ─────────────────────────────────────────────────────────
# Options: "robinhood" | "alpaca"
BROKER=robinhood

# ── Robinhood credentials ────────────────────────────────────────────────────
ROBINHOOD_USERNAME=your_robinhood_email@example.com
ROBINHOOD_PASSWORD=your_robinhood_password
ROBINHOOD_MFA_CODE=          # Leave blank if no 2FA, or enter TOTP code

# ── Alpaca credentials (alternative broker) ──────────────────────────────────
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
# Paper trading (default):
ALPACA_BASE_URL=https://paper-api.alpaca.markets
# Live trading:
# ALPACA_BASE_URL=https://api.alpaca.markets

# ── Telegram bot (manual approval) ───────────────────────────────────────────
# Create a bot via @BotFather and get your chat_id via @userinfobot
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Services ─────────────────────────────────────────────────────────────────
CIRCUIT_BREAKER_URL=http://localhost:5030

# ── App ──────────────────────────────────────────────────────────────────────
DEBUG=false
